{
  "name": "puppytimerweb",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --mac",
    "deploy": "npm run build && npx firebase deploy --only hosting"
  },
  "build": {
    "appId": "com.puppytimer.app",
    "productName": "PuppyTimer",
    "mac": {
      "category": "public.app-category.lifestyle",
      "icon": "public/icons/icon-512.png",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "PuppyTimer kopeginizi topluluk haritasinda paylasmak icin konumunuzu kullanir.",
        "NSLocationUsageDescription": "PuppyTimer kopeginizi topluluk haritasinda paylasmak icin konumunuzu kullanir."
      }
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/qrcode": "^1.5.6",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "firebase": "^12.9.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.563.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.0",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.5.1",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
