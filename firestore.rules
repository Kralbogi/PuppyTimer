rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // AUTHENTICATION HELPERS
    // ============================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // ============================================
    // USER DATA - STRICT ISOLATION
    // ============================================
    // Each user can only read/write their own profile and settings
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // DOGS - USER-OWNED WITH PUBLIC PROFILE OPTION
    // ============================================
    // Private reading: owner only
    // Public reading: anyone authenticated + visibility == "public"
    // Writing: owner only
    match /kopekler/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow read: if resource.data.visibility == "public" && isAuthenticated();
      allow write: if isOwner(userId);
    }
    
    // ============================================
    // TOILET LOGS - COMPLETELY PRIVATE
    // ============================================
    // Owner can read/write toilet records
    // This is personal health data - zero public access
    match /tuvalet_kaydi/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // HEALTH NOTES - HIPAA-LEVEL PRIVACY
    // ============================================
    // Most sensitive: only owner access
    // Vet notes, medications, allergies - never shared
    match /saglik_notlari/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // CHAT MESSAGES - CONVERSATION-BASED ACCESS
    // ============================================
    // Read: user must be participant (katilimciIds array)
    // Write: Strict validation
    //   - User must be listed in participants
    //   - Content must be string 1-500 chars
    //   - Timestamp must be valid (not future)
    //   - No malicious content patterns
    match /konusma/{conversationId}/messages/{messageId} {
      allow read: if isAuthenticated() && 
                     request.auth.uid in resource.data.katilimciIds;
      allow create: if isAuthenticated() && 
                       request.auth.uid in request.resource.data.katilimciIds &&
                       // Message content validation
                       request.resource.data.icerik is string &&
                       request.resource.data.icerik.size() > 0 &&
                       request.resource.data.icerik.size() <= 500 &&
                       // User creating message must be sender
                       request.resource.data.gonderenId == request.auth.uid &&
                       // Timestamp validation
                       request.resource.data.olusturmaTarihi is number &&
                       request.resource.data.olusturmaTarihi <= now.getTime() &&
                       request.resource.data.olusturmaTarihi > now.getTime() - 60000; // 1 min tolerance
      allow update: if isAuthenticated() && 
                       request.auth.uid == resource.data.gonderenId &&
                       // Only allow updating read status
                       request.resource.data.icerik == resource.data.icerik &&
                       request.resource.data.olusturmaTarihi == resource.data.olusturmaTarihi;
      allow delete: if isAuthenticated() && 
                       request.auth.uid == resource.data.gonderenId;
    }
    
    // ============================================
    // COMMUNITY DOGS - PUBLIC READ, OWNER WRITE
    // ============================================
    // Read: any authenticated user (community showcase)
    // Create: creator becomes sahibiId
    // Update/Delete: sahibiId only
    match /topluluk_kopekler/{document=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       request.resource.data.sahibiId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               resource.data.sahibiId == request.auth.uid;
    }
    
    // ============================================
    // RATE LIMITING - OWNER ACCESS
    // ============================================
    // Track API call frequency per user
    // Only owner can read/write their rate limit doc
    match /rate_limits/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // DENY ALL OTHERS
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
